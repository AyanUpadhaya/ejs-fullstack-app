<!-- ═══════════════════════════════════════════
     VIEW / EDIT NOTE PAGE
════════════════════════════════════════════ -->

<div class="note-editor-page">

  <!-- ── Header row ── -->
  <div class="ne-topbar">
    <div class="ne-breadcrumb">
      <a href="/dashboard" class="ne-back">
        <i class="bi bi-arrow-left"></i>
        <span>Dashboard</span>
      </a>
      <span class="ne-breadcrumb-sep">/</span>
      <span class="ne-breadcrumb-cur"><%= note.title %></span>
    </div>

    <div class="ne-actions">
      <!-- Delete trigger -->
      <button
        type="button"
        class="ne-btn-danger"
        id="deleteButton"
        data-bs-toggle="modal"
        data-bs-target="#deleteModal"
      >
        <i class="bi bi-trash3"></i>
        <span class="d-none d-sm-inline">Delete</span>
      </button>

      <a href="/dashboard" class="ne-btn-ghost">Cancel</a>

      <button type="submit" form="editNoteForm" id="updateNoteBtn" class="ne-btn-save">
        <i class="bi bi-check-lg"></i> Save Changes
      </button>
    </div>
  </div>

  <!-- ── Editor Card ── -->
  <div class="ne-card">

    <div class="ne-card-label">
      <i class="bi bi-pencil-fill"></i> EDITING
      <span class="ne-card-label-dot"></span>
      <span style="color:#34d399; letter-spacing:0.05em;">Auto-saved</span>
    </div>

    <form action="/dashboard/item/<%= noteID %>?_method=PUT" method="POST" id="editNoteForm" class="ne-form">

      <!-- Title -->
      <div class="ne-field-title">
        <input
          type="text"
          id="title"
          name="title"
          value="<%= note.title %>"
          placeholder="Note title..."
          autocomplete="off"
          class="ne-input-title"
        >
      </div>

      <!-- Divider -->
      <div class="ne-divider"></div>

      <!-- Body -->
      <div class="ne-field-body">
        <textarea
          id="body"
          name="body"
          placeholder="Write your note here..."
          rows="18"
          class="ne-textarea"
        ><%= note.body %></textarea>
      </div>

    </form>
  </div>

  <!-- Mobile save -->
  <div class="ne-mobile-save">
    <button type="submit" form="editNoteForm" class="ne-btn-save w-100">
      <i class="bi bi-check-lg"></i> Save Changes
    </button>
  </div>

</div>


<!-- ════════════════ DELETE MODAL ════════════════ -->
<div class="modal fade" tabindex="-1" role="dialog" id="deleteModal">
  <div class="modal-dialog modal-dialog-centered" role="document">
    <div class="modal-content ne-modal">

      <div class="ne-modal-header">
        <div class="ne-modal-icon">
          <i class="bi bi-exclamation-triangle-fill"></i>
        </div>
        <div>
          <h5 class="ne-modal-title">Delete note?</h5>
          <p class="ne-modal-sub">This action cannot be undone.</p>
        </div>
        <button type="button" class="btn-close btn-close-white ms-auto opacity-25" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="ne-modal-body">
        <p>
          You're about to permanently delete
          <strong style="color:#e8eaf0;">"<%= note.title %>"</strong>.
          Once deleted, this note will be gone forever.
        </p>
      </div>

      <div class="ne-modal-footer">
        <button type="button" class="ne-btn-ghost" data-bs-dismiss="modal">Keep it</button>
        <form action="/dashboard/item-delete/<%= noteID %>?_method=DELETE" method="POST">
          <button type="submit" id="confirmDeleteBtn" class="ne-btn-delete-confirm">
            <i class="bi bi-trash3-fill"></i> Delete permanently
          </button>
        </form>
      </div>

    </div>
  </div>
</div>


