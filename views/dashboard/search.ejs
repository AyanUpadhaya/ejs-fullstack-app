<div class="container-fluid container-fluid-custom py-5">

  <!-- Header -->
  <div class="row mb-4">
    <div class="col">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
          <li class="breadcrumb-item active">Search Results</li>
        </ol>
      </nav>
      <h1 class="h3 mb-0" style="font-family:'Space Grotesk',sans-serif; letter-spacing:-0.02em;">
        <i class="bi bi-search me-2" style="color:var(--accent-primary);"></i>Search Results
      </h1>
    </div>
  </div>

  <!-- Results -->
  <div class="row">
    <div class="col-12 col-lg-8">
      <% if(searchResults != '') { %>
        <% searchResults.forEach(function (note, index) { %>
          <a href="/dashboard/item/<%= note._id %>" class="search-result-item" id="searchResult<%= index %>">
            <div class="search-result-icon">
              <i class="bi bi-journal-text"></i>
            </div>
            <span><%= note.title %></span>
            <i class="bi bi-arrow-right ms-auto" style="color:var(--text-muted); font-size:0.85rem;"></i>
          </a>
        <% }) %>
      <% } else { %>
        <div class="no-results">
          <div class="empty-state-icon mb-3" style="margin:0 auto;">
            <i class="bi bi-search" style="color:var(--text-muted);"></i>
          </div>
          <p>No notes matched your search.</p>
          <a href="/dashboard" class="btn btn-ghost btn-sm mt-2">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
          </a>
        </div>
      <% } %>
    </div>
  </div>

</div>
